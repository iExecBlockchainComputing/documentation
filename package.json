{
  "name": "documentation",
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "markdownlint": "^0.27.0",
    "markdownlint-cli": "^0.33.0",
    "prettier": "^2.8.3"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "markdownlint --fix .",
    "lint-strict": "markdownlint -c .markdownlint_strict.json .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.md": [
      "prettier --write",
      "markdownlint --fix"
    ],
    "*.{json,yaml}": [
      "prettier --write"
    ]
  }
}
